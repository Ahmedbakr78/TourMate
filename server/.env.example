PORT=4000
NODE_ENV=development

# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/tourmate

# JSON Web Token
JWT_SECRET=change-me-in-production-this-is-a-long-secret-key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# CORS (comma separated allowed origins)
CORS_ORIGIN=http://localhost:4200

# External integrations
OVERPASS_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT_MS=2000
OVERPASS_CACHE_TTL_MS=3600000

OSRM_BASE_URL=https://router.project-osrm.org
# Alternative: OpenRouteService (set ORS_API_KEY to enable)
ORS_BASE_URL=https://api.openrouteservice.org
ORS_API_KEY=

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
